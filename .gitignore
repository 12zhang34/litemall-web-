# Python 编译产物
__pycache__/
*.pyc

# 虚拟环境
.venv/
venv/
env/

result/

# IDE 配置
.idea/
*.iml
.vscode/

# 测试缓存与报告
.pytest_cache/
allure-results/
allure-report/
htmlcov/
.coverage

